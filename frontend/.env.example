# AppSync GraphQL endpoint — get real values from CDK CfnOutput.
# See docs/cloud/env-distribution.md. Copy to .env.local (gitignored).
NEXT_PUBLIC_APPSYNC_URL=<appsync-graphql-endpoint>
NEXT_PUBLIC_APPSYNC_API_KEY=<key>

# Demo/offline mode: serve local queue fixtures instead of AppSync (renders
# populated rows before the backend schema lands; no live subscription).
# Set to 1 or true to enable. Leave unset for the real AppSync path.
# NEXT_PUBLIC_USE_MOCK=1

# Asset prefix for viewing the dev server behind the workshop /ports/<n>/ proxy.
# run.sh sets this automatically. Leave unset for a bare localhost run / prod.
# NEXT_PUBLIC_ASSET_PREFIX=/ports/3000
